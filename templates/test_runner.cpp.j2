string dumpJson(double v) { return to_string(v); }
string dumpJson(bool v) { return v ? "true" : "false"; }
string dumpJson(const string& v) { return "\"" + v + "\""; }
template<typename T>
string dumpJson(const vector<T>& v) {
    string s = "[";
    for (size_t i = 0; i < v.size(); i++) {
        if (i) s += ",";
        s += dumpJson(v[i]);
    }
    return s + "]";
}

